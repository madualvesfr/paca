# Local development (`expo start`) reads this file via apps/mobile/.env.
# Copy this to apps/mobile/.env and point it at your STAGING Supabase project
# so local/dev work NEVER touches production financial data.
#
# Cloud builds do NOT use this file — their values come from eas.json `env`
# per build profile (development/preview -> staging, production -> prod).
# The anon/publishable key is safe to expose (RLS-gated, ships in the binary).

EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_STAGING_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_STAGING_PUBLISHABLE_KEY
