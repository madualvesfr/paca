{
  "expo": {
    "name": "Paca Finance",
    "slug": "paca-finance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pacafinance",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF8FB1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pacafinance.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Paca Finance usa a câmera pra escanear recibos e extratos automaticamente, criando suas transações sem digitação.",
        "NSPhotoLibraryUsageDescription": "Paca Finance acessa suas fotos pra escanear recibos e extratos salvos na galeria.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
